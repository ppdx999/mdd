entity 顧客
entity 管理者

process 受注処理
process 在庫管理

datastore 注文マスタ {
  注文ID
  顧客ID
  注文日時
  配送先郵便番号
  配送先住所
  配送先氏名
  配送先電話番号
  希望配送日
  希望時間帯
  注文ステータス
  合計金額
  消費税
  割引額
  ポイント利用額
  決済方法
  決済ステータス
  備考
}

datastore 商品マスタ {
  商品ID
  商品名
  商品カテゴリ
  価格
  原価
  在庫数
  安全在庫数
  入荷予定日
  販売開始日
  販売終了日
  重量
  サイズ
}

顧客 -> 受注処理 : "注文リクエスト"
受注処理 -> 注文マスタ : "注文登録"
受注処理 -> 在庫管理 : "在庫引当依頼"
在庫管理 -> 商品マスタ : "在庫更新"
商品マスタ -> 在庫管理 : "在庫情報"
管理者 -> 商品マスタ : "商品管理"
